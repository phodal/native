.{
    .id = "dev.zero_native.ios-example",
    .name = "ios-example",
    .display_name = "iOS Example",
    .version = "0.1.0",
    .platforms = .{ "ios" },
    .permissions = .{},
    .capabilities = .{ "webview", "native_views", "native_module" },
    .commands = .{
        .{ .id = "mobile.back", .title = "Back" },
        .{ .id = "mobile.refresh", .title = "Refresh" },
    },
    .web_engine = "system",
}
