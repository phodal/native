.{
    .id = "dev.zero_native.mobile_shell",
    .name = "mobile-shell",
    .display_name = "Mobile Shell",
    .version = "0.1.0",
    .platforms = .{ "ios", "android" },
    .permissions = .{},
    .capabilities = .{ "webview", "native_views", "native_module" },
    .commands = .{
        .{ .id = "mobile.back", .title = "Back" },
        .{ .id = "mobile.refresh", .title = "Refresh" },
    },
    .web_engine = "system",
}
